generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  fullName        String
  email           String    @unique
  phone           String    @unique
  passwordHash    String
  city            String    @default("İstanbul")
  district        String    @default("Pendik")
  neighborhood    String?
  isPhoneVerified Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  isAvailable     Boolean   @default(true)
  lastSeenAt      DateTime?
  passwordChangedAt DateTime?
  profilePhotoKey String?

  professions     String[]  @default([])
  bio             String?
  workerSettings  Json?
  experiences     Json?

  warningCount    Int       @default(0)
  lastWarnedAt    DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  otpCodes        OtpCode[]

  sentMessages       Message[]        @relation("MessageSender")
  receivedMessages   Message[]        @relation("MessageRecipient")
  searchEvents       SearchEvent[]
  reportsFiled       MessageReport[]  @relation("ReportedBy")
  savedProfiles      SavedProfile[]   @relation("SavedBy")
  savedByOthers      SavedProfile[]   @relation("SavedAs")
  pushSubscriptions  PushSubscription[]
  categorySuggestions CategorySuggestion[] @relation("SuggestedBy")
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  content     String
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, read])
}

model OtpCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model JobCategory {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

model CategorySuggestion {
  id              String    @id @default(cuid())
  // Öneren kişi (kayıtlı kullanıcı; profil formundan gelir)
  userId          String
  user            User      @relation("SuggestedBy", fields: [userId], references: [id], onDelete: Cascade)
  // Kullanıcının yazdığı meslek adı (ham)
  suggestedName   String
  // Opsiyonel açıklama / not
  note            String?
  // pending | approved | rejected
  status          String    @default("pending")
  // Onaylandığında oluşturulan kategoriye işaret eder
  resultSlug      String?
  resultName      String?
  reviewedAt      DateTime?
  reviewNote      String?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
  @@index([userId])
}

model District {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String   @unique
  isEnabled     Boolean  @default(false)
  order         Int      @default(0)
  neighborhoods String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isEnabled, order])
}

model SearchEvent {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  query           String?
  professionSlug  String?
  neighborhood    String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([professionSlug])
}

model SavedProfile {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("SavedBy", fields: [userId], references: [id], onDelete: Cascade)
  savedUserId  String
  savedUser    User     @relation("SavedAs", fields: [savedUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, savedUserId])
  @@index([userId, createdAt])
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // signup | report | resolve | warn | deactivate | activate | category
  actorId   String?  // İşlemi yapan (yoksa system/anonim)
  targetId  String?  // Hedef obje (user, report, category id)
  title     String
  sub       String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
}

model MessageReport {
  id            String    @id @default(cuid())
  messageId     String
  reportedById  String
  reportedBy    User      @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: Cascade)
  reason        String
  status        String    @default("open")
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resolvedNote  String?

  @@index([status, createdAt])
  @@index([messageId])
}
