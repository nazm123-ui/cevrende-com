generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  role            String
  fullName        String
  email           String    @unique
  phone           String    @unique
  passwordHash    String
  city            String    @default("İstanbul")
  district        String    @default("Pendik")
  neighborhood    String?
  isPhoneVerified Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)

  professions     String[]  @default([])
  bio             String?
  workerSettings  Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  otpCodes        OtpCode[]
  jobPosts        JobPost[]

  sentMessages       Message[]        @relation("MessageSender")
  receivedMessages   Message[]        @relation("MessageRecipient")
  sentRequests       ContactRequest[] @relation("RequestSender")
  receivedRequests   ContactRequest[] @relation("RequestRecipient")
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  content     String
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, read])
}

model ContactRequest {
  id            String   @id @default(cuid())
  fromUserId    String
  fromUser      User     @relation("RequestSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toWorkerId    String
  toWorker      User     @relation("RequestRecipient", fields: [toWorkerId], references: [id], onDelete: Cascade)
  status        String   @default("pending")
  message       String?
  createdAt     DateTime @default(now())
  respondedAt   DateTime?

  @@unique([fromUserId, toWorkerId])
  @@index([toWorkerId, status])
}

model OtpCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model JobCategory {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  jobPosts  JobPost[]
}

model JobPost {
  id                 String      @id @default(cuid())
  employerId         String
  employer           User        @relation(fields: [employerId], references: [id], onDelete: Cascade)

  title              String
  description        String

  categoryId         String
  category           JobCategory @relation(fields: [categoryId], references: [id])

  jobType            String

  city               String      @default("İstanbul")
  district           String      @default("Pendik")
  neighborhood       String
  mapLocationUrl     String?
  latitude           Float?
  longitude          Float?

  workDate           DateTime?
  startTime          String?
  endTime            String?

  salaryAmount       Float?
  salaryType         String      @default("not_specified")

  neededPeopleCount  Int         @default(1)
  experienceRequired Boolean     @default(false)

  benefits           String      @default("")
  contactMethod      String      @default("phone")

  status             String      @default("active")

  expiresAt          DateTime
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([status, expiresAt])
  @@index([categoryId, status])
  @@index([neighborhood, status])
}
